# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# RSS Configuration (comma-separated feed URLs)
RSS_FEED_URL=https://news.ycombinator.com/rss,https://feeds.bbci.co.uk/news/rss.xml

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=sentiment-backend
KAFKA_TWEET_TOPIC=tweet_topic
KAFKA_SENTIMENT_TOPIC=sentiment_topic

# Database Configuration (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=sentiment_user
DB_PASSWORD=sentiment_pass
DB_NAME=sentiment_db

# Memcached Configuration
MEMCACHED_SERVERS=localhost:11211

# RSS relevance controls
RSS_ENABLE_FALLBACK_FEEDS=false
RSS_MAX_ARTICLE_AGE_HOURS=24

# Keep live streams clean by clearing old rows for selected topic on start
RESET_TOPIC_ON_STREAM_START=false
